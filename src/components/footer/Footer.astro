---
import Brand from './Brand.astro';
import FooterColumn from './FooterColumn.astro';
import FooterLink from './FooterLink.astro';
import SocialLink from './SocialLink.astro';

const year = new Date().getFullYear();

const footerColumns = [
  {
    title: 'Servicios',
    links: [
      { href: '#', label: 'Desarrollo Web' },
      { href: '#', label: 'Diseño UI/UX' },
      { href: '#', label: 'Apps Móviles' },
      { href: '#', label: 'Consultoría' },
    ],
  },
  {
    title: 'Compañía',
    links: [
      { href: '#', label: 'Nosotros' },
      { href: '#', label: 'Portafolio' },
      { href: '#', label: 'Carreras' },
      { href: '#', label: 'Blog' },
    ],
  },
];

const socialLinks = [
  { href: '#', icon: 'public', label: 'Website' },
  { href: '#', icon: 'alternate_email', label: 'Email' },
];
---

<footer class="bg-surface text-foreground p-10">
  <div class="mx-auto max-w-7xl">
    <div class="border-border grid grid-cols-1 gap-8 border-t pt-10 md:grid-cols-4">
      <Brand />

      {
        footerColumns.map((column) => (
          <FooterColumn title={column.title}>
            {column.links.map((link) => (
              <FooterLink href={link.href} label={link.label} />
            ))}
          </FooterColumn>
        ))
      }

      <div>
        <h4 class="mb-4 font-bold">Social</h4>

        <div class="flex gap-4">
          {
            socialLinks.map((social) => (
              <SocialLink href={social.href} icon={social.icon} label={social.label} />
            ))
          }
        </div>
      </div>
    </div>

    <div
      class="border-border text-surface-foreground/60 mt-10 flex flex-col items-center justify-between gap-4 border-t pt-6 text-xs md:flex-row"
    >
      <p class="text-center md:text-left">
        © {year} Laviro Web Solutions. Todos los derechos reservados.
      </p>

      <div class="flex gap-4">
        <a href="#" class="hover:text-secondary transition-colors duration-300">
          Política de Privacidad
        </a>

        <a href="#" class="hover:text-secondary transition-colors duration-300">
          Términos de Servicio
        </a>
      </div>
    </div>
  </div>
</footer>
