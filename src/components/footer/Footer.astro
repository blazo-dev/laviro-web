---
import Brand from './Brand.astro';
import FooterColumn from './FooterColumn.astro';
import FooterLink from './FooterLink.astro';
import SocialLink from './SocialLink.astro';

const year = new Date().getFullYear();
---

<footer class="bg-surface text-foreground p-10">
  <div class="mx-auto max-w-7xl">
    <div class="border-border grid grid-cols-1 gap-8 border-t pt-10 md:grid-cols-4">
      <Brand />

      <FooterColumn title="Servicios">
        <FooterLink href="#" label="Desarrollo Web" />
        <FooterLink href="#" label="Diseño UI/UX" />
        <FooterLink href="#" label="Apps Móviles" />
        <FooterLink href="#" label="Consultoría" />
      </FooterColumn>

      <FooterColumn title="Compañía">
        <FooterLink href="#" label="Nosotros" />
        <FooterLink href="#" label="Portafolio" />
        <FooterLink href="#" label="Carreras" />
        <FooterLink href="#" label="Blog" />
      </FooterColumn>

      <div>
        <h4 class="mb-4 font-bold">Social</h4>
        <div class="flex gap-4">
          <SocialLink href="#" icon="public" />
          <SocialLink href="#" icon="alternate_email" />
        </div>
      </div>
    </div>

    <div
      class="border-border text-surface-foreground/60 mt-10 flex flex-col items-center justify-between gap-4 border-t pt-6 text-xs md:flex-row"
    >
      <p class="text-center md:text-left">
        © {year} Laviro Web Solutions. Todos los derechos reservados.
      </p>

      <div class="flex gap-4">
        <a href="#" class="hover:text-secondary transition-colors duration-300">
          Política de Privacidad
        </a>
        <a href="#" class="hover:text-secondary transition-colors duration-300">
          Términos de Servicio
        </a>
      </div>
    </div>
  </div>
</footer>
