---

<section class="bg-background relative px-6 py-24" id="nosotros">
  <div class="mx-auto max-w-7xl">
    <!-- Header -->
    <div class="mb-16 text-center">
      <h2 class="text-primary mb-2 text-sm font-semibold tracking-wide uppercase">El Equipo</h2>

      <h3 class="text-foreground mb-6 text-4xl font-bold">Mentes Creativas</h3>
    </div>

    <!-- Grid Wrapper -->
    <div class="relative">
      <div class="grid grid-cols-1 items-stretch gap-8 md:grid-cols-3">
        {
          team.map((member) => (
            <div class="flex h-full w-full">
              <TeamCard {...member} />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
